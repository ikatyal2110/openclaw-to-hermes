      "description": "Triage incoming alerts, escalate by severity, and notify a fan-out of recipients with retries.",
      "id": "workflow.incident_response.d0465068",
      "inputs": [],
      "intent": {
        "confidence": 0.95,
        "description": "Triage incoming alerts, escalate by severity, and notify a fan-out of recipients with retries.",
        "evidence": [
          "description field present"
        ],
        "source": "static"
      },
      "kind": "workflow",
      "metadata": {
        "has_branches": true,
        "raw_steps": [
          {
            "id": "parse",
            "plugin": "parse_alert",
            "with": {
              "payload": "${trigger.body}"
            }
          },
          {
            "id": "classify",
            "plugin": "classify_severity",
            "with": {
              "alert": "${steps.parse.output}"
            }
          },
          {
            "id": "page",
            "plugin": "pagerduty_create",
            "retry": {
              "backoff": "exponential",
              "initial_delay_seconds": 2,
              "max_attempts": 3
            },
            "when": "${steps.classify.output.severity == 'critical'}",
            "with": {
              "summary": "${steps.parse.output.summary}",
              "token": "${env.PAGERDUTY_TOKEN}"
            }
          },
          {
            "for_each": "${steps.classify.output.subscribers}",
            "id": "notify",
            "plugin": "send_email",
            "retry": {
              "backoff": "linear",
              "max_attempts": 2
            },
            "with": {
              "body": "${steps.parse.output.summary}",
              "to": "${item.email}"
            }
          }
        ],
        "triggers": [
          {
            "kind": "webhook",
            "path": "/alerts/incoming"
          }
        ]
      },
      "name": "incident_response",
