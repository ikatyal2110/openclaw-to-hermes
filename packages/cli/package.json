{
  "name": "@praxis/cli",
  "version": "0.1.0",
  "description": "Thin TypeScript wrapper around praxis-core. Shells out to python -m praxis_core.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "praxis": "dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
